# ============================================
# CLM-lite + Proposal Generator — Environment
# ============================================

# --- App ---
APP_ENV=development          # development | production
APP_SECRET_KEY=change-me-to-a-random-string
APP_HOST=0.0.0.0
APP_PORT=8000
DEV_LOGIN_ENABLED=true       # Enable "dev login" bypass (local testing only)

# --- Database ---
DATABASE_URL=postgresql+asyncpg://clm:clm_secret@db:5432/clm_db
DATABASE_URL_SYNC=postgresql://clm:clm_secret@db:5432/clm_db
POSTGRES_USER=clm
POSTGRES_PASSWORD=clm_secret
POSTGRES_DB=clm_db

# --- OIDC (Azure AD / Google) ---
OIDC_PROVIDER_URL=https://accounts.google.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback

# --- Pipedrive ---
PIPEDRIVE_API_TOKEN=your-pipedrive-api-token
PIPEDRIVE_BASE_URL=https://api.pipedrive.com/v1
PIPEDRIVE_MOCK_MODE=true     # Use mock data instead of real Pipedrive

# --- AI (configured via Setup Wizard, these are fallback defaults) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MOCK_MODE=true     # Use mock AI responses

# OpenRouter (optional, configure via Admin Settings)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# --- SMTP (optional) ---
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=clm@example.com

# --- Storage ---
GENERATED_DOCS_PATH=/app/generated_docs
UPLOAD_PATH=/app/uploads
